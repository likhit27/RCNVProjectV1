generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Club {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  createdAt DateTime?  @default(now()) @db.Timestamp(6)
  users     ClubUser[]
  dues      Due[]
  members   Member[]
  news      News[]
  projects  Project[]
  sessions  Session[]
}

model ClubUser {
  id        String    @id @default(cuid())
  clubId    String
  email     String
  password  String
  role      String?   @default("member")
  memberId  String?
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  club      Club      @relation(fields: [clubId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  member    Member?   @relation(fields: [memberId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([clubId, email])
}

model Member {
  id              String    @id @default(cuid())
  clubId          String
  rotaryId        String?
  name            String
  email           String?
  phone           String?
  classification  String?
  occupation      String?
  principalActivity String?
  inductionDate   DateTime? @db.Timestamp(6)
  proposedBy      String?
  dateOfBirth     DateTime? @db.Timestamp(6)
  anniversary     DateTime? @db.Timestamp(6)
  address         String?
  businessName    String?
  businessTagline String?
  businessAddress String?
  photoUrl        String?
  spouseName      String?
  spouseEmail     String?
  spousePhone     String?
  spouseDob       DateTime? @db.Timestamp(6)
  createdAt       DateTime? @default(now()) @db.Timestamp(6)
  updatedAt       DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  children        Child[]
  dues            Due[]
  users           ClubUser[]
  club            Club      @relation(fields: [clubId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([clubId])
}

model Child {
  id          String    @id @default(cuid())
  memberId    String
  name        String
  dateOfBirth DateTime? @db.Timestamp(6)
  member      Member    @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Project {
  id          String    @id @default(cuid())
  clubId      String
  title       String
  avenue      String
  description String?
  startedAt   DateTime? @default(now()) @db.Timestamp(6)
  status      String?   @default("active")
  club        Club      @relation(fields: [clubId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model News {
  id        String    @id @default(cuid())
  clubId    String
  title     String
  body      String
  pinned    Boolean?  @default(false)
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  club      Club      @relation(fields: [clubId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Due {
  id        String    @id @default(cuid())
  clubId    String
  memberId  String
  amount    Decimal   @db.Decimal(10, 2)
  paid      Boolean?  @default(false)
  dueDate   DateTime? @db.Timestamp(6)
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  club      Club      @relation(fields: [clubId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Session {
  id        String    @id @default(cuid())
  clubId    String
  email     String
  token     String    @unique
  expiresAt DateTime  @db.Timestamp(6)
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  club      Club      @relation(fields: [clubId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
